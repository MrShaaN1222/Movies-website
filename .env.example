# Backend
PORT=4000
# Local: docker compose up -d mongo  →  mongodb://127.0.0.1:27017/mirai_movies_ai
# Atlas: use your SRV string; in Atlas → Network Access, allow your IP or 0.0.0.0/0 (dev only).
MONGODB_URI=mongodb://127.0.0.1:27017/mirai_movies_ai
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000,https://miraimoviesai.vercel.app,https://mirai-movies-ai.netlify.app
TMDB_API_KEY=
YOUTUBE_API_KEY=
# Razorpay — add RAZORPAY_KEY_ID and RAZORPAY_KEY_SECRET here (repo root .env) for live UPI/card checkout on /purchase
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PLAYBACK_SIGNING_SECRET=

# Frontend
# IMPORTANT: In production, set this to your hosted backend URL (never localhost).
# Example: NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:4000
